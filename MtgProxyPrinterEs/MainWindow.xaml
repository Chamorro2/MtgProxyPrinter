<Window x:Class="MtgProxyPrinterEs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MtgProxyPrinterEs.ViewModels"
        xmlns:conv="clr-namespace:MtgProxyPrinterEs.Converters"
        Title="{DynamicResource Title}" Height="700" Width="1100"
        Background="#1a1a2e" WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="500">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>

        <SolidColorBrush x:Key="BgDark" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="BgPanel" Color="#16213e"/>
        <SolidColorBrush x:Key="BgInput" Color="#0d1b2a"/>
        <SolidColorBrush x:Key="BgCard" Color="#0f3460"/>
        <SolidColorBrush x:Key="Accent" Color="#e94560"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#e94560"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c73652"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0f3460"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a4a80"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0d1b2a"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#e94560"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0d1b2a"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#e94560"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a4a80"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#0f3460"/>
        </Style>

        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#e94560"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#0f3460"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#0f3460">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="8" Height="28" Background="#e94560"
                            CornerRadius="4" Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource Title}"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="App:" Foreground="#a0a0b0" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AppLanguages}"
                              SelectedItem="{Binding AppLanguage, Mode=TwoWay}"
                              Width="60" FontSize="12"
                              IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>

                    <Separator Width="1" Height="24" Margin="12,0"/>

                    <TextBlock Text="{DynamicResource Language}" Foreground="#a0a0b0" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding PreferredLanguage, Mode=TwoWay}"
                              Width="75" FontSize="12"
                              IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>

                    <Separator Width="1" Height="24" Margin="12,0"/>

                    <Button Content="{DynamicResource LoadSample}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadSampleDeckCommand}"
                            FontSize="11" Padding="10,6"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="{DynamicResource DeckListHeader}" Foreground="#e94560"
                               FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="{DynamicResource DeckListHint}"
                               Foreground="#555" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#0f3460" BorderThickness="1"
                        CornerRadius="6" ClipToBounds="True">
                    <TextBox AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding DeckListText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" BorderThickness="0"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                </Border>

                <Button Grid.Row="2" Content="{DynamicResource LoadCards}"
                        Margin="0,8,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadCardsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#0f3460" ResizeBehavior="PreviousAndNext"/>

            <!-- COLUMNA CENTRAL -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="{DynamicResource CardsLoaded}" Foreground="#e94560"
                               FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="#555" FontSize="10"
                               Text="{Binding DeckEntries.Count, StringFormat='{}{0} entradas', Mode=OneWay}"/>
                </Grid>

                <Border Grid.Row="1" BorderBrush="#0f3460" BorderThickness="1"
                        CornerRadius="6" ClipToBounds="True">
                    <ListBox ItemsSource="{Binding DeckEntries}"
                             SelectedItem="{Binding SelectedEntry}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="ListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#e94560"
                                            CornerRadius="4" Width="22" Height="22"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Quantity}"
                                                   Foreground="White" FontWeight="Bold"
                                                   FontSize="11" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="8,0,4,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CardName}"
                                                   Foreground="White" FontWeight="SemiBold"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="10" Foreground="#a0a0b0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="{DynamicResource ArtButton}"
                                            FontSize="10" Padding="8,4"
                                            Style="{StaticResource SecondaryButton}"
                                            Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVis}}"
                                            Tag="{Binding}"
                                            Click="ArtButton_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                          Background="#0f3460" ResizeBehavior="PreviousAndNext"/>

            <!-- COLUMNA DERECHA -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{DynamicResource PreviewHeader}"
                           Foreground="#e94560" FontWeight="Bold" FontSize="11"
                           Margin="0,0,0,6"/>

                <Border Grid.Row="1" Background="#0d1b2a" CornerRadius="8"
                        BorderBrush="#0f3460" BorderThickness="1">
                    <Grid>
                        <TextBlock Text="{DynamicResource PreviewPlaceholder}"
                                   Foreground="#444" TextAlignment="Center"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontSize="12"/>
                        <Image x:Name="PreviewImage" Stretch="Uniform" Margin="8"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                    <TextBlock Text="{Binding SelectedEntry.CardName}"
                               Foreground="White" FontWeight="Bold" FontSize="12"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedEntry.SelectedPrint.DisplayInfo}"
                               Foreground="#a0a0b0" FontSize="10" TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Row="3" Content="{DynamicResource GeneratePdf}"
                        Margin="0,12,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding GeneratePdfCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
            </Grid>
        </Grid>

        <!-- BARRA DE ESTADO -->
        <Border Grid.Row="2" Background="#0f3460" Padding="12,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#a0a0b0" FontSize="11"
                           VerticalAlignment="Center"/>
                <ProgressBar HorizontalAlignment="Right" VerticalAlignment="Center"
                             Width="180" Height="5"
                             Value="{Binding ProgressValue}"
                             Maximum="{Binding ProgressMax}"
                             Background="#1a1a2e" Foreground="#e94560"
                             Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>